    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Speaking, reading, and writing proficiency in Italian required. Critical study of The Decameron. Critical approach designation: Canons, Genres. Distribution requirements: Poetry, Pre-1750.",
    section: ["FREE"], rmpScore: 0
