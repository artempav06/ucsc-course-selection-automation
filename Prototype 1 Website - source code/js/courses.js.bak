    units: 5, division: "upper",
    prereqs: [["LIT 181E"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Close reading of the Tale of Sinuhe in Middle Egyptian. Critical approach designations: Genres, Geographies. Distribution requirements: Global, Poetry, Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 181G": {
    title: "Sanskrit, Part 1",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Systematic introduction to the grammar, syntax, and usage of Classical Sanskrit, to the oral dimensions of the language, and to the Sanskrit literary tradition. Critical approach designations: Canons, Histories. Distribution requirements: Global, Poetry, Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 181H": {
    title: "Sanskrit, Part 2",
    units: 5, division: "upper",
    prereqs: [["LIT 181G"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Continued study of the grammar, syntax, and usage of Classical Sanskrit, and the Sanskrit literary tradition. Students read the entire Bhagavad-Gita, including key sections in the original Sanskrit. Critical approach designations: Canons, Geographies. Distribution requirements: Global, Poetry, Pre-1750. Together, LIT 181G and LIT 181H , Sanskrit Parts 1 and 2, fulfill the language prerequisites for Literature 102; together they also satisfy the intensive major second-language course requirements.",
    section: ["FREE"], rmpScore: 0
  },
