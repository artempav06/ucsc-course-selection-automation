  "BIOE 121": {
    title: "Plants, Earth, Climate",
    units: 5, division: "upper",
    prereqs: [["BIOL 20A"], ["BIOE 20B"], ["BIOE 20C"]],
    ge: "PE-E", quarters: ["F", "W", "S"],
    desc: "Explores how biotic and abiotic factors shaped the Earth’s biosphere and how climate change will challenge the resilience of plant life on the planet. By the end of the course, students will better understand the broader implications of plant function on the health of the planet. Topics include core plant physiological processes and how they feed into climate feedback loops, photosynthesis and the formation of the atmosphere, plants and the paleoclimate, plant adaptations and resilience, climate change mitigation through plants, and more.",
    section: ["FREE"], rmpScore: 0
  },
