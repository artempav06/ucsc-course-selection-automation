    section: ["FREE"], rmpScore: 0
  },
  "BME 1": {
    title: "Introduction to Biomolecular Engineering Problem Solving",
    units: 2, division: "lower",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Introduction to biomolecular engineering through identification of current problems and their solutions. Intended for any student interested in BME. Students critically read primary research articles, search scientific literature, and identify relevant, trustworthy sources of information. Students learn about the engineering design process and common experimental tools used in biomolecular engineering research. Major course assignments include writing assignments and a team presentation.",
    section: ["FREE"], rmpScore: 0
  },
  "BME 5": {
    title: "Introduction to Biotechnology",
    units: 5, division: "lower",
    prereqs: [],
    ge: "PE-T", quarters: ["F", "W", "S"],
    desc: "Introduces the tools and applications of biotechnology in the fields of medicine, agriculture, the environment, and industry.",
    section: ["FREE"], rmpScore: 0
  },
  "BME 18": {
    title: "Scientific Principles of Life",
    units: 5, division: "lower",
    prereqs: [],
    ge: "SI", quarters: ["F", "W", "S"],
    desc: "The principles of life as it exists on this planet and how they generalize. Darwinian evolution, genomes, scientific theories of life (mechanistic, thermodynamic, information theoretic). Future of life: Internet, machine learning and adaptation, artificial intelligence, genome editing, fully artificial life.",
    section: ["FREE"], rmpScore: 0
  },
  "BME 21L": {
    title: "Introduction to Basic Laboratory Techniques",
    units: 3, division: "lower",
    prereqs: [["CHEM 1M"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Laboratory course providing hands-on training in fundamental techniques used to express, isolate, and analyze genes in prokaryotic cells. Introduction to common laboratory instruments and fundamental skills required for basic research in molecular biology and biomolecular engineering.",
    section: ["FREE"], rmpScore: 0
  },
  "BME 22L": {
    title: "Foundations of Design and Experimentation in Molecular Biology",
    units: 2, division: "lower",
    prereqs: [["BME 21L"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Project-based laboratory course providing hands-on training in fundamental molecular biology and biomolecular engineering techniques used to manipulate expression of DNA and proteins in prokaryotic cells. Students are introduced to essential processes in experimental design. (Formerly Foundations of Design and Experimentation in Molecular Biology, Part I.)",
    section: ["FREE"], rmpScore: 0
  },
  "BME 23L": {
    title: "Foundations of Design and Experimentation in Molecular Biology, Part II",
    units: 2, division: "lower",
    prereqs: [["BME 22L"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Laboratory-based course extending the wet lab skills developed in the first two quarters of the BME 2x series with bioinformatics skills that form the foundation of biomolecular engineering. Focuses on sequencing of low-diversity environmental samples, including: field sampling, DNA extraction from those samples, library preparation, hands-on sequencing using a Nanopore device, base-calling of the raw data, assembly of contigs, quality assessment, contig assignment to species/bins, automated annotation of a single assemblage from collection genome publication.",
    section: ["FREE"], rmpScore: 0
  },
  "BME 35": {
    title: "Strategies for a Successful Summer Internship",
    units: 10, division: "lower",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Open only to UCSC students in the QB3 Summer Internship Program. Course provides hands-on experience working in a lab on campus or at an industry partner. It is designed for students to integrate an intensive research experience with their major and prior coursework. Enrollment is by permission of the instructor.",
    section: ["FREE"], rmpScore: 0
  },
  "BME 51A": {
    title: "Applied Electronics for Bioengineers Part 1",
    units: 5, division: "lower",
    prereqs: [["MATH 19A"], ["MATH 11A"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Lab-based course that introduces measuring, modeling, and designing electronics circuits, emphasizing voltage dividers and complex impedance culminating in simple, negative-feedback op amp circuits for amplifying audio signals.",
    section: ["FREE"], rmpScore: 0
  },
  "BME 51B": {
    title: "Applied Electronics for Bioengineers Part 2",
    units: 5, division: "lower",
    prereqs: [["BME 51A"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Lab-based course that introduces designing, measuring, and modeling electronics circuits, emphasizing RC filters and negative-feedback amplifiers for various sensors circuits for amplifying audio signals, design of multi-stage amplifiers, instrumentation amplifiers, and class-D power amplifiers.",
    section: ["FREE"], rmpScore: 0
  },
  "BME 55": {
    title: "Introduction to Lab Groups",
    units: 2, division: "lower",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Course intended to assist second-year biomolecular engineering and bioinformatics undergraduates find research labs that they might join. Students sit in on different lab group meetings, read papers recommended by the lab groups, and report back to other students in the class both verbally and in writing. Course is offered for pass/no pass only.",
    section: ["FREE"], rmpScore: 0
  },
  "BME 80G": {
    title: "Bioethics in the 21st Century: Science, Business, and Society",
    units: 5, division: "lower",
    prereqs: [],
    ge: "PE-T", quarters: ["F", "W", "S"],
    desc: "Serves science and non-science majors interested in bioethics. Guest speakers and instructors lead discussions of major ethical questions having arisen from research in genetics, medicine, and industries supported by this knowledge.",
    section: ["FREE"], rmpScore: 0
  },
  "BME 80H": {
    title: "The Human Genome",
    units: 5, division: "lower",
    prereqs: [],
    ge: "PE-T", quarters: ["F", "W", "S"],
    desc: "Course will focus on understanding human genes. Accessible to non-science majors. Will cover principles of human inheritance and techniques used in gene analysis. The evolutionary, social, ethical, and legal issues associated with knowledge of the human genome will be discussed.",
    section: ["FREE"], rmpScore: 0
  },
  "BME 94": {
    title: "Group Tutorial",
    units: 5, division: "lower",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
