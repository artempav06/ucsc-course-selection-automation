    units: 5, division: "upper",
    prereqs: [],
    ge: "TA", quarters: ["F", "W", "S"],
    desc: "Examines mid- to late-19th-century English representations of non-normative gender and sexuality in popular culture. Considers how these figures in fiction conform to or resist established perceptions of gender, sexuality, race, and empire. Critical approach designations: Histories, Power and Subjectivities.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 147A": {
