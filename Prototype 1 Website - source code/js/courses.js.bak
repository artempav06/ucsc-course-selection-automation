  "HIS 178B": {
    title: "European Intellectual History: The 19th Century",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Study of European thought and literature from Blake to Nietzsche. Focuses on relation of ideas to their social and cultural context. Special attention to the rise and fall of the Romantic movement, to changing conceptions of history, and to the development of socialist and aesthetic critiques of industrial civilization.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 178C": {
    title: "European Intellectual History, 1870-1970",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Drawing on experiments in autobiography, the arts, and social theory, this course focuses on ideas and images of modernity in European culture. It also highlights the role of the intellectual as politically engaged or disillusioned witness in a violent century.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 178E": {
    title: "Modern Jewish Intellectual History",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Surveys European Jewish intellectual history from the Enlightenment to the present. Major themes include emancipation and assimilation, the flowering of Yiddish literature, the rise of Zionism, new variations on the messianic idea, and Jewish contributions to the culture of urban modernism.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 181": {
    title: "Modern Britain and the British Empire",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Examines the history of the British Isles and the British Empire from the late 17th century to the present. Traces the expansion, transformation, and dissolution of the British Empire as well as the changing meanings of Englishness and Britishness over this period.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 181B": {
    title: "Africa and Britain in an Imperial World",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Covers the long history of interaction between Britain and Africa, from the Atlantic slave trade and British colonialism in Africa up to the post-colonial present, from British settlers in Africa to the African presence in the British Isles.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 184B": {
    title: "Racism and Antiracism in Europe: From 1870 to the Present",
    units: 5, division: "upper",
    prereqs: [],
    ge: "TA", quarters: ["F", "W", "S"],
    desc: "Explores the histories of racism and anti-Semitism alongside efforts to combat racism in Europe from 1870 to the present. Offers a conceptual basis for thinking about the definition of race and its historical evolution.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 185C": {
    title: "Communism, Nationalism, and Zionism: Comparative Radical Jewish Politics",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Comparative in approach, course examines Jewish radical politics across Europe, North Africa, the Middle East, and the Americas in the late 19th and 20th centuries. How did radical politics afford Jews greater agency in contexts that otherwise excluded them? What tensions arose with religious, nationalist, and internationalist obligations? What drew so many Jews across so many diverse contexts to focus on radical leftist politics? What, if anything, links Jews and radical politics across such diverse contexts? Through primary sources, memoirs, scholarly works, films and more, students compare Jewish engagement in radical leftist movements in several nodes, including Russia (and the former USSR), Poland, France, Egypt, Iraq, Morocco, Israel, Argentina, Mexico, and the USA among others.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 185I": {
    title: "Latin American Jewish History in the Modern Period",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Explores Jewish immigration settlement and identity negotiation in Latin America from the mid-19th Century to the present.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 185J": {
    title: "The Modern Jewish Experience",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Historical comparative overview of the political, socio-cultural, and intellectual transformation of Jewish societies in Europe and the Middle East from the late 18th Century to the present.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 185K": {
    title: "Jewish Life in Eastern Mediterranean Port Cities",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Overview of the Jewish experience in important cities in the age of empire. Istanbul, Beirut, Alexandria, and Salonica were home to thriving, culturally diverse Jewish populations. Course explores these urban Jewish cultures, the institutions, and intellectual production.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 185L": {
    title: "Where Civilizations Met--Jews, Judaism, and the Iberian Peninsula",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Surveys Jewish life in the Iberian Peninsula from Roman times to the present, and explores offshoot Hispanic Jewish societies in the aftermath of the 1492 expulsion.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 185M": {
    title: "Zionism: An Intellectual History",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Zionism is one of the most complex--and contested--political and ideological movements of the modern period. This course explores the intellectual history of Zionism and its critics, from the late 19th century to the establishment of the State of Israel.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 185O": {
    title: "The Holocaust and the Arab World",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Examines World War II in North Africa and the Middle East. Through primary and secondary sources, films, and novels, students consider WWII and the Holocaust as they intersect with colonial and Jewish histories in the Arab world.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 188A": {
    title: "Introduction to the Practice of Oral History",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PR-S", quarters: ["F", "W", "S"],
    desc: "Introduces students to the method of oral history. Familiarizes students with the history of the method’s development in the U.S. and other global contexts and with past and ongoing oral history projects at UCSC. As a practice-based course, provides hands-on tools and experiential learning opportunities in order to craft and execute an original oral history interview. Trains students in interviewing best practices as well as transcription and indexing conventions. Designed to support and contribute to campus- and community-based research initiatives.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 189": {
    title: "@history: Doing History in a Digital Age",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PR-E", quarters: ["F", "W", "S"],
    desc: "Investigates questions relating to how new technologies are changing the way historians do research and interact with the public. This course has both a critical classroom component and a hands-on computer laboratory component.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190A": {
    title: "Slavery and Race in Latin America",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Covers comparative history of slavery in Latin America with questions of race in the colonial and national periods and key moments and debates in the historiography of slavery and its relation to ideologies of the past and the nations.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190B": {
    title: "Race and the Nation in Latin America",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Focuses on the ways in which nation and race have been thought about in Latin America throughout the 19th and 20th centuries. These concepts were closely intertwined, albeit in differing and changing ways, since the wars of independence from Spain and Portugal (1810-1825). Compares the ways in which black, Indian, and racially mixed (mulatto or mestizo) have been socially constructed, ideologized, and contended in different countries, including Brazil, the Spanish-speaking Caribbean, Mexico, Peru, and Argentina.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190D": {
    title: "Asian and Latino Immigration Since 1875",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Examines Asian and Latino immigration into the United States since 1875. Students explore the relationship between U.S. foreign policies and immigration policies, transnational ties and homeland connections, and the cultural and political influences they have on American society.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190E": {
    title: "Topics in Chicana/o History",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "A seminar on the history of Chicanos/Mexicans in the United States, 1848 to the present. Topics include Chicana/o labor, family, social, urban, cultural, and political history.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190F": {
    title: "Research Seminar in the Americas",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Students learn how to conduct research and write history. Primary and secondary sources are extensively read. Research sources include a rich array of government documents, newspapers, memories and diaries, visual material and film.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190G": {
    title: "Comparative History of Redress and Reparations",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Explores why after World War II and especially in the past 30 years, demands for redress and reparations for war crimes, genocide, mass violence, slavery, colonialism, and other injustices proliferated. Students compare different views on the benefits of confronting the past, identifying perpetrators, and providing justice in multiple countries. Students also analyze how race, ethnicity, religion, class, and gender shaped injustices and assessments of reparations by public officials, international investigators, survivors, and descendants of victims. Topics include tribunals, prosecutions, truth commissions, apologies, restitution, compensation, and memorialization.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190H": {
    title: "History of Time",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Writing-intensive seminar on the experience, manipulation, and representation of time in history. Students pursue advanced research using primary and secondary sources.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190J": {
    title: "Mexican History in the Archives",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Explores the history of early Mexico (the Colonial Era through the mid-19th century) through original archival research. Includes field trips to regional archives and research libraries. Reading knowledge of Spanish is recommended.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190K": {
    title: "Wired Planet: Readings on the Global History of Broadcasting and Telecommunications",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Locates common themes in the history of broadcasting and telecommunications throughout the world. Why do certain strategies for developing broadcasting and telecommunications systems succeed or fail? Why do some nations outstrip other nations of comparable development in the growth of their communications systems? Why do national or regional communication systems suddenly become more or less open, or more or less centralized?",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190N": {
    title: "Topics in African History",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Examines topics in Early Modern and Modern African history, such as: arts and material culture; African religions and their interchanges with major world religions; statebuilding, local political institutions, and African political thought; African and European empires in Africa; agriculture, environment, and economic development; and the Atlantic and Indian worlds of Africa, among others. Seminar format where students will be prepared to undertake studies on specific subjects and handle primary sources, work on oral presentation skills, and develop a research article.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190P": {
    title: "Early American Society and Culture",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Explores subjects and themes in the political, social, and cultural history of early U.S. history from the colonial period through 1850. Includes critical reading of current scholarship and research in primary texts. The focus of this course is the production of a 25-page research paper. Recommended for senior history majors.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190Q": {
    title: "The Novel and History",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Explores novels and novelists in relation to the writing of historical scholarship. Breaking down the simplistic genre division between fiction and nonfiction, provides opportunities for students to read novels as historical evidence, novels as editorial commentary, and novels as analytical narrative. Students produce a series of papers that culminate in a 25-page research project.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190R": {
    title: "Research in the History of American Religions",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Readings and research in the history of religions in the United States. Readings focus on topics including the rise of evangelicalism; gender and religion; class, race, and religious diversity; and modernity. Students produce papers that culminate in a 25-page research project.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190T": {
    title: "Latin America in the Cold War",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Writing-intensive seminar on Latin America during the Cold War. Particular attention given to U.S.-Latin American relations, including moments of covert or direct interventions. Students pursue advanced research using primary and secondary sources.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190U": {
    title: "Power, Culture, and the Federal Bureau of Investigation",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "In this research seminar, students explore F.B.I. files obtained under the Freedom of Information Act on a prominent citizen of the United States of America.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190V": {
    title: "Myths of California",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "The history of California has been shrouded in myths. The historian Richard White describes myths as \"timeless stories that differ from history\" and \"are not so much falsehoods as explanations.\" This course studies the history of myths that have shaped how many people in California understand the past, including myths about the histories of Indigenous peoples, European explorers, Spanish missions, the Gold Rush, and different visions of \"the California Dream.\" In the final assessment for the course, students use historical thinking to create a research paper to challenge a mythic representation of California history.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190W": {
    title: "U.S. Civil War and Reconstruction",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Students read historiographically significant works in the history of the U.S. Civil War and Reconstruction. Students develop research projects grounded in primary source material on a related topic of their choosing. (Formerly Topics in U.S. Civil War and Reconstruction.)",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190X": {
    title: "History of the Atlantic World, 1492-1824",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Explores the transatlantic societies created by Europeans' colonization of the Americas, and their exploitation of African slaves. Questions whether the cultural, economic, and political links across the ocean integrated the adjacent lands into a fundamentally Atlantic World.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190Y": {
    title: "The Atlantic Slave Trade",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Before 1800, far more Africans than Europeans colonized the Americas, arriving unwillingly in the slave trade. Course examines the captives' experiences; the trade's organization and significance in the Atlantic economy; and the eventual movement to abolish the traffic.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 190Z": {
    title: "The Long Civil Rights Movement",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Explores the concept of the long civil rights movement as a framework for understanding a wide range of social, economic, and political developments in the African American freedom struggle, in both North and South, from the 1930s through the 1980s.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 192": {
    title: "Directed Student Teaching",
    units: 5, division: "upper",
