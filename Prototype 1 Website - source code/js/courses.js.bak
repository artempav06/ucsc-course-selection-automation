    units: 5, division: "lower",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Surveys 3,000 years of Jewish literature and culture. Themes include origins of the Jews in the ancient world; formation and persistence of the Jewish diaspora; coherence and diversity of Jewish experience; Jewish narrative and textual traditions; interaction between Jews and other cultures; tensions between tradition and modernity.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 61K": {
