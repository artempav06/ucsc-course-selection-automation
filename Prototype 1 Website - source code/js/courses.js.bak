  "BIOE 128L": {
    title: "Large Marine Vertebrates Field Course",
    units: 7, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Lectures combined on fieldwork with large marine vertebrates in the laboratory and lectures with large marine vertebrates in the field (Monterey Bay, Ano Nuevo). Fieldwork familiarizes students with research methods, study design, and statistical approaches for research on large marine vertebrates (seals, birds, fish, and sharks). Research includes: animal tracking; physiology; behavior; foraging ecology; and energetics. Prerequisite(s): BIOL 20A and BIOE 20B and BIOE 20C , and satisfaction of the Entry Level Writing and Composition requirements.",
