    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "To allow promising, well-qualified undergraduates to pursue directed programs of archival or archaeological study in the field under supervision of the UCSC history faculty, concentrating their work within a single given quarter. Students may take two or three courses concurrently. Students submit petition to sponsoring agency.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 194C": {
    title: "Topics in Modern Chinese History",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Explores important themes in modern Chinese history ranging from empire and nation-state formation, foreign imperialism, revolutionary movements and politics, global capitalism, and social and cultural change. Teaches the writing of a major research paper using primary and secondary sources.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 194E": {
    title: "Women in Japanese History",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Examines through both primary and secondary sources such issues as work, sexuality, education, class, and ethnicity in relation to constructions of female gender in Japanese society over the past several centuries, particularly focusing on the modern era.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 194K": {
    title: "Topics in the History of Southeast Asia",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Examines the history of lands, peoples, and cultures in Southeast Asia. Covers case studies from early modern history, imperial contact, colonization, decolonization, as well as contemporary political and social conditions, including studies of displacement and im/migration. Topics include comparative studies of colonialisms in the region; historiography of Southeast Asian studies in the United States; Southeast Asian technoscience and medicine; environmental history and eco-activism. As this course also qualifies as a senior exit seminar for history majors, the course dives into the particulars of academic research and writing. Students produce an original research paper that will be scaffolded throughout the term.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 194L": {
    title: "Exile, Diaspora, and Displacement: Jewish Lives from North Africa to the Middle East",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "From Medieval Spain, Ottoman Salonica, 20th-century Baghdad, present day Casablanca, and beyond, this course examines Jewish experiences of exile, diaspora, and displacement, as well as how to read memoir and biography as sources in their broader historical context.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 194M": {
    title: "Literati, Samurai, and Yangban: Comparative History of State and Elite in East Asia, 1600-1900",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Critically examines the formation of political elites in East Asia. Compares literati in Ming and Qing, China; samurai in Tokugawa, Japan; and yangban in Joeson, Korea. Each group occupied specific roles and functions in their state and society but differed in scale and character. Students cannot receive credit for this course and HIS 294M .",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 194N": {
    title: "Urbanites in the Global South, 18th Century to the Present",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Urbanization is an important aspect of the making of the Global South. This course introduces the histories of urbanization from the 18th Century to the present. Students read the works of historians, anthropologists, geographers, and sociologists.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 194O": {
    title: "South Asia in the Twentieth Century",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Introduces students to key ideas and ideologues of the Indian nation and the practices of the late-colonial and post-colonial Indian State. In the process, students become familiar with themes like modernity, gender, state formation, space, nationalism, democracy, and development.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 194P": {
    title: "Urban South Asia",
    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Introduces important themes in urban studies in South Asia in the pre-modern and modern periods. These include political economic change; competing imaginations of city life; urban politics; land use; urban planning; and cultural life among others. This course begins with a brief survey of urbanism in pre-modern South Asia but focuses mostly on urbanities in the early modern and modern periods.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 194Q": {
