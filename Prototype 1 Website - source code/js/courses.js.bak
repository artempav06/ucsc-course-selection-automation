    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Speaking, reading, and writing proficiency in French required. A discussion of recent developments in French literary theory. Critical approach designations: Canons, Geographies.",
    section: ["FREE"], rmpScore: 0
