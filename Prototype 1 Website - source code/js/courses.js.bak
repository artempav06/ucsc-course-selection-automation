    units: 5, division: "upper",
    prereqs: [],
    ge: "TA", quarters: ["F", "W", "S"],
    desc: "Surveys representations of the Euro-Amerindian encounter in the pre-national period. Readings include collective stories of indigenous peoples, European captivity narratives, reflections about spirituality and religion, poems, and a contemporary novel. Critical approach designations: Histories, Power and Subjectivities. Distribution requirement: Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 146A": {
