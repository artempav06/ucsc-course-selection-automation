  "LIT 139B": {
    title: "Los Angeles Circa 1992",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "In response to the acquittal of white police who brutally beat black motorist Rodney King, thousands of people took to the street. This course examines cultural narratives that arose in the lead-up to and aftermath of the 1992 L.A. uprising. Critical approach designations: Geographies, Power and Subjectivities.",
