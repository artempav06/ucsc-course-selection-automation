    desc: "Explores the history of telecommunications systems in the US starting with the telegraph, the telephone, wireless telegraph, radio, television and the Internet. Students learn about the development of these systems and the cultures that they foster.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 117A": {
    title: "From the Player Piano to Pandora",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Explores the history, culture, and politics of the distribution of recorded and live sound from the 1870s through the present.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 118": {
