    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Speaking, reading, and writing proficiency in Italian required. Reading of the Inferno, the Purgatorio, and selected canti of the Paradiso, along with selections from Dante's lyrics and from medieval Italian and French poetry. Critical approach designations: Canons, Histories. Distribution requirements: Poetry, Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 185S": {
