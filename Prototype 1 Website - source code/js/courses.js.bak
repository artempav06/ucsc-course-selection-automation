    units: 5, division: "upper",
    prereqs: [["BIOL 20A"], ["BIOE 20B"], ["BIOE 20C"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Provides students with a broad genetics background. Topics range from understanding the flow of genetic information within single-celled organisms to how genes and gene products function within multicellular organisms. Students learn how genotype shapes phenotype and its role in evolution and ecology.",
    section: ["FREE"], rmpScore: 0
  },
  "BIOE 107": {
