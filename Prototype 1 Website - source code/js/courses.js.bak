    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Covers from the Cuban sugar revolution (late 18th century) to the socialist revolution and its aftermath (1959–present). It is intended to be not only a modern history of Cuba but also a broader history of Latin America through the case of Cuba.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 131": {
