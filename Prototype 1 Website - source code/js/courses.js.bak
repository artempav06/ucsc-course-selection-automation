    units: 5, division: "upper",
    prereqs: [],
    ge: "TA", quarters: ["F", "W", "S"],
    desc: "Investigates the representation of slavery with scholarly and vernacual histories, focusing on the United States. Students examine representations of slavery in scholarly works, public-history venues like museums and historic sites, popular culture, and artistic productions. Students develop their own scholarly research into the history of slavery grounded in primary and secondary sources.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 117": {
