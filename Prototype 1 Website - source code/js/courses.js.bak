    prereqs: [],
    ge: "TA", quarters: ["F", "W", "S"],
    desc: "Examines literature's relationship to the past and to the experience of history. Course topic changes; please see the Class Search for current topic.",
    section: ["FREE"], rmpScore: 0
  },
