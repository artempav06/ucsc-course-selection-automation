    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Examines the cultural, political, and environmental upheaval associated with antebellum market revolution. Topics include: markets and U.S. territorial expansion; reform movements that coalesced around disputes over what should, and should not be sold (e.g., antislavery activism; anti-prostitution reform movements).",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 116": {
