    ge: null, quarters: ["F", "W", "S"],
    desc: "Covers the principles, control, the theory of accounting for liabilities and property; plant and equipment, the preparation and analysis of investments,and review and analysis of bonds and leases.",
    section: ["FREE"], rmpScore: 0
  },
  "ECON 111C": {
