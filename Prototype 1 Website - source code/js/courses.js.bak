  "LIT 179C": {
    title: "Methods and Materials",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PR-C", quarters: ["F", "W", "S"],
    desc: "Focuses on a particular process or subject used in the production of a literary text. Course is intended to work as a bridge between invention and scholarship. Course topic changes; please see the Class Search for current topic.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 179E": {
    title: "Writing for Transformation",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PR-C", quarters: ["F", "W", "S"],
    desc: "Introductory cross-genre writing workshop exploring the social and political engagements of a wide array of BIPOC authors’ work. In interactive lectures and small group discussion,students analyze authors’ use of craft and form to inspire creation of our own poetry, flash nonfiction, and flash fiction. Course considers how authors thematize family, community, language, activism, love, culture, health, state and structural violence, relations with our natural environment, and more.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 181A": {
    title: "Biblical Hebrew, Part 1",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Grammatical study interspersed with narrative excerpts from the Hebrew Bible. Recommended: previous study of a second language up to the advanced level. Critical approach designations: Canons, Histories. Distribution requirements: Global, Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 181B": {
    title: "Biblical Hebrew, Part 2",
    units: 5, division: "upper",
    prereqs: [["LIT 181A"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Continuation of grammatical study interspersed with poetic texts from the Hebrew Bible. Critical approach designations: Genres, Geographies. Distribution requirements: Global, Poetry, Pre-1750. Together, Biblical Hebrew 1 and Hebrew 2 fulfill the language prerequisites for LIT 102 ; together they also satisfy the intensive major second-language course requirements.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 181C": {
    title: "Coptic",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Intensive introduction to fundamentals of classical Coptic grammar (Sahidic dialect) designed to move rapidly into reading of primary texts. Readings include The Martyrdom of S. Coluthus, Gospel of Thomas, and the Gnostic treatise Thunder: Perfect Mind. Critical approach designations: Genres, Histories. Distribution requirement: Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 181D": {
    title: "Reading Egyptian Hieroglyphs, Part 1",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Introduction to Egyptian hieroglyphs as a graphic, conceptual, and communicative system. Covers the basic elements of classical Egyptian grammar, drawing primarily on inscriptions from extant Egyptian monuments. Students read one prose and one poetical text from the Middle Kingdom. Critical approach designations: Geographies, Media. Distribution requirement: Global, Pre-1750. Strongly recommended: two years previous study of a foreign language at the college level or the equivalent.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 181E": {
    title: "Reading Egyptian Hieroglyphs, Part 2",
    units: 5, division: "upper",
    prereqs: [["LIT 181D"]],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Advanced Middle Egyptian grammar (two weeks). Close reading of the Tale of Sinuhe in Middle Egyptian, selected hymns and love poetry from the New Kingdom. Critical approach designations: Genres, Geographies. Distribution requirement: Global, Poetry, Pre-1750. Together, LIT 181D and LIT 181E , Egyptian Hieroglyphs 1 and 2, fulfill the language prerequisites for LIT 102 ; together they also satisfy the intensive major second-language course requirements.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 181F": {
