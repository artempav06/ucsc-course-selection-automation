    ge: null, quarters: ["F", "W", "S"],
    desc: "The second course in UCSC's three-quarter introductory chemistry series. Topics in this quarter include chemical equilibrium, acids and bases, solution pH, buffers and chemical kinetics. Course consists of in-person lecture and a secondary active learning discussion section. In addition to the lecture, students are required to enroll and attend one discussion section.",
    section: ["FREE"], rmpScore: 0
  },
  "CHEM 3BL": {
