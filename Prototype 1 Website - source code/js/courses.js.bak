    desc: "Provides for department-sponsored individual field study in the vicinity of campus under the direct supervision of a faculty sponsor. May not be counted toward major requirements. Students submit petition to sponsoring agency.",
    section: ["FREE"], rmpScore: 0
  },
  "SOCY 193I": {
