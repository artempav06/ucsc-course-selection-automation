    ge: null, quarters: ["F", "W", "S"],
    desc: "Complex functions, complex analysis, asymptotic series and expansions, special functions defined by integrals, and probability and statistics. (Formerly offered as PHYS 116B.)",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 120": {
    title: "Polymer Physics",
    units: 5, division: "upper",
    prereqs: [["PHYS 112"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Statistical properties polymers; scaling behavior, fractal dimensions; random walks, self avoidance; single chains and concentrated solutions; dynamics and topological effects in melts; polymer networks; sol-gel transitions; polymer blends; application to biological systems; computer simulations will demonstrate much of the above. Students cannot receive credit for this course and PHYS 240.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 129": {
    title: "Particle Physics and Astrophysics",
    units: 5, division: "upper",
    prereqs: [["PHYS 5D", "PHYS 102"], ["MATH 23B"], ["PHYS 116A", "MATH 21"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "The standard model of particle physics; physics beyond the standard model; neutrino physics; the early universe; dark matter and dark energy; selected topics in general relativistic cosmology and high-energy astrophysics. (Formerly Nuclear and Particle Astrophysics.)",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 130": {
    title: "Multiwavelength Astronomical Techniques",
    units: 5, division: "upper",
    prereqs: [["PHYS 102"], ["PHYS 133"], ["ASTR 19", "ASTR 119", "CSE 20"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Survey of observational astronomy across the electromagnetic spectrum and including multi-messenger probes. Covers the physics of light detection and instrumentation in different wavelength bands as well as astrophysical sources of emission and the relevant radiative processes associated to them. Aspects of statistics and statistical inference relevant for astronomical data analysis are also covered.",
    section: ["FREE"], rmpScore: 0
  },
