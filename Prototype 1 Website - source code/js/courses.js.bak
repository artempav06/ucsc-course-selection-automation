  "BME 188A": {
    title: "Synthetic Biology--Mentored Research A",
    units: 2, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "This two-credit course is the first of three courses in a 12-credit collaborative research project available to students in physical sciences, and biomolecular engineering intended to satisfy the capstone requirement. Provides a multidisciplinary, collaborative research experience working on a project in synthetic biology. Working with one or more research faculty, student teams complete a substantial project. Multiple oral/written presentations are required, including a formal conference presentation. Prerequisite(s): BME 180 . Enrollment is restricted to juniors and seniors. Enrollment is by instructor permission.",
    section: ["FREE"], rmpScore: 0
  },
  "BME 188B": {
