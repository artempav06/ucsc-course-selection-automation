  "CHEM 186L": {
    title: "Research Communication and Practice",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Complements undergraduate research experience in chemistry and biochemistry with skill development in communicating science and discussion of the responsible practice of science. Students complete written summaries and presentations describing their original research. Additional topics include record keeping, research funding and grant writing, scientific publishing, and ethics and misconduct. Students must be sponsored by a research mentor. Prerequisite(s): CHEM 8M . Students must have active mentorship from department faculty. Enrollment is by permission of the instructor.",
