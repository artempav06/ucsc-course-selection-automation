  "ANTH 2": {
    title: "Introduction to Cultural Anthropology",
    units: 5, division: "lower",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "A number of different peoples are studied and a variety of approaches to the nature of the culture and to the study of specific cultures presented. Required for all anthropology majors.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 3": {
    title: "Introduction to Archaeology",
    units: 5, division: "lower",
    prereqs: [],
    ge: "SI", quarters: ["F", "W", "S"],
    desc: "Overview of ways of learning about the human past beyond the scope of written history. Reviews development of archaeology, fundamental methods and theories, and archaeology's contribution to understanding human origins, the emergence of farming, and the origins of complex societies.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 93": {
    title: "Field Study",
    units: 5, division: "lower",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Supervised research or organized projects on anthropological topics for lower-division students. Conducted either on or off campus. Students submit petition to sponsoring agency.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 97": {
    title: "Laboratory Safety Practicum",
    units: 2, division: "lower",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Covers laboratory health and safety and standard operating procedures within the anthropology laboratories. Prepares students for future laboratory research activities while providing support of laboratory administration, collections management, and laboratory course demonstration needs. Enrollment by application.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 100": {
    title: "History and Theory of Biological Anthropology",
    units: 5, division: "upper",
    prereqs: [["ANTH 1", "ANTH 2"], ["ANTH 3"]],
    ge: "TA", quarters: ["F", "W", "S"],
    desc: "Provides an historical overview from the 18th century to the present of race, ape-human relationships, and human nature. Emergence of an evolutionary framework and of fossil, genetic, and primate information becomes the basis for reformulating ideas about human biology within anthropology.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 109": {
    title: "Stable Isotope Ecology in Anthropology and Beyond",
    units: 5, division: "upper",
    prereqs: [["ANTH 1", "BIOE 20C"]],
    ge: "SI", quarters: ["F", "W", "S"],
    desc: "Provides students with a comprehensive overview and solid theoretical framework regarding the most common isotope systems used in anthropology and related disciplines, which include carbon, nitrogen, oxygen, strontium, and sulfur.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 101": {
    title: "Human Evolution",
    units: 5, division: "upper",
    prereqs: [["ANTH 1"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Study of human evolution covering the last five million years. Examines the fossil evidence and emphasizes the reconstruction of behavior from the paleontological and anatomical evidence.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 102A": {
    title: "Human Skeletal Biology",
    units: 5, division: "upper",
    prereqs: [["ANTH 1"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Presents basic human osteology allowing students to identify skeletal material by element. Emphasizes the dynamic nature of bone by integrating anatomy with a discussion of bone physiology within the context of the human life cycle.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 103": {
    title: "Forensic Anthropology",
    units: 5, division: "upper",
    prereqs: [["ANTH 102A"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Covers the basic analysis of human skeletal remains for the medicolegal profession. Assessment of age, sex, ancestry, and general physical characteristics, trauma, and disease are discussed. Addresses the legal responsibilities of the anthropologist. Online lectures with in-class discussion sections, quizzes, and exams. Students cannot receive credit for this course and ANTH 103I.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 104": {
    title: "Human Variation and Adaptation",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Explores the major environmental factors (temperature, altitude, diet, and disease); how they are perceived by the human body; the physiological, micro- and macroanatomical responses; and how behavior and culture can modify the impact of these stresses. ANTH 1 is highly recommended as preparation. (Formerly Human Adaptability.)",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 105": {
    title: "Human Paleopathology",
    units: 5, division: "upper",
    prereqs: [["ANTH 1"], ["ANTH 102A"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Examines paleopathology beginning with ancient hominid populations and proceeding to modern populations. Uses both the skeletal evidence and historical documentation when available. Considers evolutionary, cultural, and biological factors. Topics include: osteological diagnosis of infectious disease; trauma; nutritional deficiencies; dental disease; and developmental defects.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 106": {
    title: "Primate Behavior and Ecology",
    units: 5, division: "upper",
    prereqs: [["ANTH 1"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "The nature of primate social systems and social bonds is examined in the light of evolutionary and ecological concepts. We explore the evolution of primate social system behavior and culture, as well as the ecologies of primate populations.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 106A": {
    title: "Chimpanzee Behavior and Culture A",
    units: 2, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Provides students with an in-depth understanding of the non-invasive study of chimpanzee behavior via video footage. The interactive lab aspect of this class focuses on how to non-invasively monitor the presence and behavioral diversity of wildlife, using camera trap technology. Students are exposed to the primary scientific literature and gain experience handling and maintaining large datasets in excel, and work as a team throughout this class. Prerequisite(s): ANTH 1 . Enrollment is by permission of the instructor.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 106B": {
    title: "Chimpanzee Behavior and Culture",
    units: 2, division: "upper",
    prereqs: [["ANTH 106A"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Provides students with an in depth understanding of the non-invasive study of chimpanzee behavior from video footage. The interactive lab aspect of this class focuses on how to non-invasively monitor the presence and behavioral diversity of wildlife using camera trap technology. Students are exposed to the primary scientific literature and gain experience handling and maintaining large datasets in excel, and work as a team throughout this class.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 106C": {
    title: "Chimpanzee Behavior and Culture",
    units: 2, division: "upper",
    prereqs: [["ANTH 106B"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Provides students with an in depth understanding of the non-invasive study of chimpanzee behavior from video footage. The interactive lab aspect of this class focuses on how to non-invasively monitor the presence and behavioral diversity of wildlife using camera trap technology. Students are exposed to the primary scientific literature and gain experience handling and maintaining large datasets in excel, and work as a team throughout this class.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 107A": {
    title: "Methods and Research in Biological Anthropology: Genetics",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Introduces the molecular analyses of anthropological questions and explores the intersection of genetics and anthropology. Covers the basic principles of molecular and population genetics as they relate to the study of humans. Prerequisite(s): ANTH 1 and ANTH 104 . ANTH 102A is recommended. Enrollment by permission of instructor. (Formerly ANTH 107, Methods and Research in Molecular Anthropology.)",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 107B": {
    title: "Methods and Research in Biological Anthropology: Stable Isotopes",
    units: 5, division: "upper",
    prereqs: [["ANTH 101", "ANTH 104", "ANTH 106", "ANTH 107", "ANTH 110F"]],
    ge: "PE-H", quarters: ["F", "W", "S"],
    desc: "This combination of lectures, readings, discussions, and hands-on laboratory experience provides a comprehensive overview of stable isotope research to reconstruct diet and mobility. Discover the wide application of isotopic research in biological anthropology, bioarcheology, primatology and forensics. Prerequisite(s): at least one of ANTH 101 , ANTH 104 , ANTH 106 , ANTH 107, or ANTH 110F and by permission of the instructor. (Formerly Methods and Research in Stable Isotope Ecology.)",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 107C": {
    title: "Methods and Research in Biological Anthropology: Chimpanzee Behavior and Culture",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Lab class analyzing trail camera footage from chimpanzees and other wildlife, and installing our own cameras in the UCSC forest. Also includes readings and discussion of papers related to the newest findings on chimpanzee behavioral diversity and culture. Prerequisite(s): ANTH 106 . Enrollment is by instructor consent.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 107D": {
    title: "Methods and Research in Biological Anthropology–Computational Population Genetics",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Practical introduction to computational population genetics. Covers the basic principles of population and evolutionary genetics, and explores those with a range of computational methods for the analysis of genetic diversity, population structure, and admixture. Enrollment is by instructor consent.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 107E": {
    title: "Methods And Research In Biological Anthropology: Lithic Technology",
    units: 5, division: "upper",
    prereqs: [["ANTH 3"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Introduction to lithic and ceramic analysis in archaeology. Includes lab analysis, discussions of classification and typology, and exploration of the concept of style as it relates to ceramics and lithics in archaeology. (Formerly ANTH 182A, Lithic Technology.)",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 108": {
    title: "Neanderthals",
    units: 5, division: "upper",
    prereqs: [["ANTH 1"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Homo sapiens neanderthalensis (neanderthals), once considered brutish, are increasingly seen as behaviorally modern. This course uses primary academic research to explore the social behaviors, technology, anatomy, and genetics of neanderthals, gaining a holistic understanding of our closest ancestor.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110A": {
    title: "Public Life and Contemporary Issues",
    units: 5, division: "upper",
    prereqs: [],
    ge: "IM", quarters: ["F", "W", "S"],
    desc: "How can cultural anthropology help us to understand current events unfolding locally, nationally, and globally? Students learn how to read newspapers differently--that is, through the lens of cultural analysis. The world of everyday politics and society, as it unfolds in debates happening right now, forms the topical substance of the course.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110B": {
    title: "From Indiana Jones to Stonehenge: Archaeology as Popular Culture",
    units: 5, division: "upper",
    prereqs: [],
    ge: "IM", quarters: ["F", "W", "S"],
    desc: "Addresses the meaning of archaeology as generated in television, movies, literature, newspapers, and even National Geographic. Students engage with several case-studies illustrating how archaeology is portrayed in popular culture.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110C": {
    title: "California Pasts",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "This course is structured around four critical moments--missionization, Rancho-Era, Gold Rush, and World War II--through the eyes of the ethnic and racial minorities who experienced them. Special attention is given to oral, archival, and archaeological sources which reveal California's multiethnic pasts.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110D": {
    title: "Tourism Imaginaries and Encounters",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-H", quarters: ["F", "W", "S"],
    desc: "Explores anthropological approaches to the study of tourism, in particular themes of authenticity, othering, visual economies, development, identity politics, alternative tourisms, and material culture with reference to history, power, and location.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110E": {
    title: "Anthropology of Global Environmental Change",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-E", quarters: ["F", "W", "S"],
    desc: "Introduces anthropological and historical approaches to environmental change and globalization. Key themes include: capitalism and industrialization, environmental politics, global culture, and relations between humans and other species.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110F": {
    title: "Evolution of Human Diet",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-H", quarters: ["F", "W", "S"],
    desc: "Presents the evolution of human diet and subsistence from a biological anthropological perspective. Covers the key hypothesis and methodologies related to diet, from our early fossil ancestors up to agriculture and animal husbandry. (Formerly Biocultural Approaches to Food.)",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110G": {
    title: "Westside Stories: Race, Place and the California Imaginary",
    units: 5, division: "upper",
    prereqs: [],
    ge: "IM", quarters: ["F", "W", "S"],
    desc: "From South Central to La Misión, this course explores the role of race and culture in creating the California Dream. Draws on films, music, and activism as lenses into the complex flows of power that shape our communities.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110H": {
    title: "Brazilian Amazon Cultures and Environments",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-E", quarters: ["F", "W", "S"],
    desc: "General introduction to the astonishing diversity of cultures and environments in the Brazilian Amazon. Designed to provide upfront understanding of what underlies perverse (non)development and forest destruction, but also social defense of the forest and sustainable life within it.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110I": {
    title: "Cultures of Sustainability and Social Justice",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-E", quarters: ["F", "W", "S"],
    desc: "Brings together diverse forms of cultural knowledge and complexities of everyday life to illuminate longstanding concerns of sustainability and justice. Investigates multiple theories of sustainable development as well as tools, techniques, and contexts for ecological integrity, economic security, empowerment, responsibility and social well-being characteristic of sustainable communities. Case studies are drawn from around the world highlighting the work of Right Livelihood Award Laureates in tandem with UC faculty.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110IG": {
    title: "Cultures Of Sustainability And Social Justice Abroad",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-E", quarters: ["F", "W", "S"],
    desc: "Brings together diverse forms of cultural knowledge and complexities of everyday life to illuminate longstanding concerns of sustainability and justice. Investigates multiple theories of sustainable development as well as tools, techniques, and contexts for ecological integrity, economic security, empowerment, responsibility and social wellbeing characteristic of sustainable communities. Case studies highlight the work of Right Livelihood Award Laureates in tandem with UC faculty. This course is a hybrid course. The in-person component allows for an in-person study abroad experience whereby students visit sites relevant to the curriculum and have lectures and discussions with Right Livelihood Laureates and the instructor. The asynchronous online component facilitates student engagement with custom pre-recorded video interviews with UC faculty and Right Livelihood Laureates from around the world.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110J": {
    title: "Emerging Humanity",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Using an anthropological and archaeological perspective to learn about human history before AD 1500, course explores fossil remains of human ancestors and traces the more recent history of humanity from forgers/hunters to the emergence of complex societies/civilizations. Topics include human biological evolution, the development of organized human societies, the origins of food production (domestication of plants and animals), the origins of the world's earliest urban centers, and the development of social inequality.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110K": {
    title: "Culture Through Food",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Examines anthropology of food and politics of eating. Cultural and social uses of food in rituals of solidarity or fasting, identities and meanings of food for individuals, and consumption in the global context are key components of study.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110M": {
    title: "Cultures of Mental Health",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-H", quarters: ["F", "W", "S"],
    desc: "Examines diversity of mental health across cultures, psychiatric categories, and institutions. Assessment of human experiences via illness narratives, ethnographic research, and historical contexts.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110L": {
    title: "The Human Ocean",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-E", quarters: ["F", "W", "S"],
    desc: "From coral reefs to Arctic sea ice, this course examines how humans interact with and transform earth's oceans, and how humans are shaped by the sea. Topics include: marine conservation, migration, shipping and logistics, slavery, fisheries management, and climate change.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110N": {
    title: "Anthropology of Food",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-H", quarters: ["F", "W", "S"],
    desc: "Focuses on social institutions around the world that shape food and its meanings; how people use food to organize their worlds; and production, sharing, or consumption of food as a political or meaningful act.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110O": {
    title: "Postcolonial Britain and France",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Transdisciplinary examination of the politics and culture of postcolonial Britain and France. Topics include: immigration from South Asia, Africa, and the Caribbean; racism and antiracism; minority difference and citizenship practices; and the emergence of Islam as a major category of identity and difference.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110P": {
    title: "India and Indian Diaspora through Film",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Students in this course view the complexity and diversity of the Indian Diaspora through themes such as family, caste, food, gender, politics, religion, sexuality, and immigration policies affecting the diaspora. How do the vastly diverse groups of Indian Americans perceive their own ethnic identity? How do they respond to the dual impulses of assimilation and integration? And how might their self-conception influence the composition of their social networks? Course explores these themes through readings and Bollywood films.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110Q": {
    title: "Queer Sexuality in Black Popular Culture",
    units: 5, division: "upper",
    prereqs: [],
    ge: "IM", quarters: ["F", "W", "S"],
    desc: "From Janet Mock to Young M.A., queerness has become hypervisible in Black popular culture--but at what cost? Using music, television, and social media as central texts, students investigate the intersections of sexuality, gender, and race in public life.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110R": {
    title: "Discourses in American Religions and Their Role in Public Life",
    units: 5, division: "upper",
    prereqs: [],
    ge: "IM", quarters: ["F", "W", "S"],
    desc: "Introduces dominant discourses about major American religions and their role in public life, with particular attention to intersecting differences, such as race, sex/gender, and disability, and to shifting religious/political boundaries. Visual and textual media, political commentary, and popular ethnographies are analyzed.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110S": {
    title: "Evolution of Democracy",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-H", quarters: ["F", "W", "S"],
    desc: "Examines the state and its institutions from a historical, social, and cross-cultural perspective, paying attention to the varied discourses and practices that constitute what we call the state.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110T": {
    title: "Motherhood in American Culture",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Examines the culture wars around motherhood in the United States with a focus on the political mobilization of normative ideas about the correct way to mother, from the moment of conception on. Special attention is given to the historical construction of deviant motherhood among marginalized groups.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110U": {
    title: "Histories and Cultures of Piracy",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "An interdisciplinary yet anthropologically informed approach to studying pirates and piracy across different historical eras and spaces. Explores the role of pirates in world history from ancient to present times, including piracy both at sea and online.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110V": {
    title: "American Capitalism",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-H", quarters: ["F", "W", "S"],
    desc: "Capitalism shapes our lives in unequal ways, but what is it? Course explores histories and machinations of capitalism in the Americas, focusing on the United States. Investigates what capitalism is, how it operates, its origins, and what might come next.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110Y": {
    title: "Feeding California",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-H", quarters: ["F", "W", "S"],
    desc: "Online course introducing students to social practices, political processes, and cultural contexts that shape food production and consumption. Considers identity, heritage, choice, power, agency, body practices, belonging, access, safety, and security. Prioritizes California case studies, with comparative examples from around the world.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 110Z": {
    title: "Introduction to Disability Studies",
    units: 5, division: "upper",
    prereqs: [],
    ge: "TA", quarters: ["F", "W", "S"],
    desc: "Provides an introduction to the interdisciplinary field of disability studies, including the key terms and debates of disability studies; representations of disability in print, televisual, and social media; and the legal, political, and justice-oriented frameworks that impact disability in the U.S., with a focus on intersectional disability justice.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 111": {
    title: "Human Ecology",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Reviews the environmental, physiological, behavioral, and cultural ways that humans interact with their physical surroundings. The effects of human culture on the environment and of the environment on the shape of human culture is emphasized.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 112": {
    title: "Life Cycles",
    units: 5, division: "upper",
    prereqs: [["ANTH 1"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Examines the human life cycle using an evolutionary framework. Examines key aspects of the human life stages using findings and concepts from developmental biology, physiology, nutrition, evolutionary ecology, and life-history theory.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 113": {
    title: "Tutoring Writing in Anthropology",
    units: 2, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Trains students to tutor writing in undergraduate anthropology courses; supports and guides them during the quarter they are tutoring. Enrollment by interview only. Prerequisite(s): satisfaction of the Composition requirement.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 119": {
    title: "Indigenous Visual Culture",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Examines the relationship between visual cultures and indigenous peoples. First, class discusses what is visual anthropology. Second, class examines the relationship between museums and indigenous peoples. Third, class examines ethnographic photography and indigenous uses of photography. Fourth, class examines the uses of ethnographic film, and then its relationship to indigenous peoples. Finally, class examines indigenous uses of film.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 121": {
    title: "Socialism",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Ethnography-based course that examines the social worlds of socialism, with particular focus on state socialism. Topics include: social problems that inspired socialist movements; implementation and experience of socialism in daily life; and significance of class, race, nation, science, technology, rationality.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 122": {
    title: "Postsocialism",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Examines the demise of socialist systems. Addresses the political, social, cultural, and economic experiences of everyday life that led to that demise, what new social inequalities have arisen since, and how citizens use the socialist past to critique the present.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 123": {
    title: "Psychological Anthropology",
    units: 5, division: "upper",
    prereqs: [["ANTH 2"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "An introduction to some of the central theoretical issues in psychological anthropology. Psychoanalytic, cognitive, and relativist perspectives on the link between person and society are discussed and compared.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 124": {
    title: "Anthropology of Religion",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Study of the phenomenon of religion as manifested in ethnographic literature, with special attention to traditional and recent modes of analysis of religious behavior. Special topics include myth, religious healing, witchcraft and sorcery, ritual, and millenarian movements.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 125": {
    title: "Magic, Science, and Religion",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-H", quarters: ["F", "W", "S"],
    desc: "With a theoretical understanding of the concepts of magic, science, and religion, students draw on ethnographies of these practices to critique distinctions between them and critically analyze the understanding of these categories and their relation in the modern world",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 126": {
    title: "Contraband: Shadow Economies and the Law",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Course takes an interdisciplinary approach to studying contraband and smuggling. Focusing on concepts used to describe illegality we examine how \"shadow economies\" are central to the making of states and sovereignty, the legal and illegal being blurred.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 127": {
    title: "Ethnographies of Capitalism",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Challenges approaches to capitalism that treat it as socioeconomic relations separable from culture. Readings include ethnographies demonstrating the inextricability of cultural meanings from capitalist practices. Topics include capitalism's relationship to colonialism, nationalism, socialism, gender, and the commodification of aesthetics.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 128": {
    title: "Contemporary American Evangelical Cultures",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Study of contemporary, American, born-again Protestant discourse using ethnographic materials and interpretive theories. Topics include biblical literalism, Christian conversion and self-fabulation, charismatic gifts, preaching, sacrificial giving, prosperity theology, apocalypticism, creationism, pro-family and pro-life rhetoric, and televangelism. (Formerly Born-Again Religion and Culture .)",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 129": {
    title: "Beyond Borders: Other Globalizations and Histories of Interconnection",
    units: 5, division: "upper",
    prereqs: [["ANTH 2"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "The history of social and cultural interconnections at a global scale. Anthropological approaches to the study of cultural encounter are used to investigate topics such as trade, religion, and citizenship and to evaluate shifting concepts of civilization and barbarism. (Formerly Other Globalizations: Cultures and Histories of Interconnection.)",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 130A": {
    title: "Anthropology of Africa.",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Survey of sub-Saharan societies. Analysis of principles of social organization and factors of cultural unity of selected western, eastern, central, and southern African peoples. (Formerly Peoples and Cultures of Africa)",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 130B": {
    title: "Brazil",
    units: 5, division: "upper",
    prereqs: [["ANTH 2"]],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Examines Brazilian culture and its link to interpersonal relationships, religion, politics, and psychological experience.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 130C": {
    title: "Politics and Culture in China",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Joins substantive information about Chinese society and culture with debates in social theory and rethinks conventional wisdom about colonialism and modernity. Topics include representations of Chineseness, class revolution, Chinese diaspora, popular culture, family and kinship, nationalism, history/memory, race and gender.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 130D": {
    title: "The Cultural Aspects of the Israeli-Palestinian Conflict",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Course examines the everyday life of the Palestinian citizens of Israel.‎ Palestinians who ‎‎remained within what became the State of Israel after the 1948 war became a national and ethnic minority overnight. Although granted citizenship, they were excluded from the Jewish ‎majority society and were ‎discriminated against by the state‎. Course deepens the understanding of the conflict while focusing on the complex relations between the Palestinian and Jewish citizens in Israel, highlights the Palestinians' social and cultural aspects, and sheds light on how they ‎‎experience everyday life as a minority. Students learn how to apply sociological and anthropological approaches to understand better the Israeli-Palestinian conflict and minority-majority relations in general. ‎",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 130E": {
    title: "Culture and Politics of Island Southeast Asia",
    units: 5, division: "upper",
    prereqs: [["ANTH 2"]],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Southeast Asia includes a variety of societies exhibiting many ecological adaptations, religions, marriage systems, and experiences with colonial powers. Case studies of particular societies, chosen to reveal variety, are examined comparatively. Emphasis on religion and social organization.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 130F": {
    title: "Blackness In Motion: Anthropology of the African Diasporas",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "What connects Black communities in the Caribbean, the U.S., Latin America, and Canada, and what sets them apart? Examines theories of diaspora, gender and sexuality, slavery, colorism, music, U.S. hegemonies, social movements, and comparative racialization and global anti-blackness (Formerly Blackness In Motion: Anthology of the African Diasporas.)",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 130G": {
    title: "Asian Americans in Ethnography and Film",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Critically examines category of Asian Americans. Addresses historic representations of Asians and Asian Americans in ethnographic research and film. Explores contemporary issues of race, culture, and politics through ethnographic practice and cultural production.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 130H": {
    title: "Ethnography of Russia and Eastern Europe",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Introduces students to the ethnography of Eurasia, with special attention to the lived experience and legacy of state socialism in this region. Topics include new ideas of personhood, changing economic practices, public health, and international development.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 130I": {
    title: "Cultures of India",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "An examination of anthropological studies of tribal, rural, and urban cultures of India and a look at changes taking place in India.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 130IG": {
    title: "Cultures of India Abroad",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "An examination of anthropological studies of tribal, rural, and urban cultures of India and a look at changes taking place in India.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 130J": {
    title: "Politics and Statemaking in Latin America",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Introduction to ethnohistory and political anthropology of one or more Latin American countries: Typically Mexico and one other country. Students explore how contested concepts such as indigeneity, nation or state come to gain credibility and are deployed in contemporary politics.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 130K": {
    title: "Food Cultures in South Asia",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Designed to prepare students to adopt food as an analytical lens to explore the relationship between environmental sustainability and social justice in the South Asia. It draws from ethnographic texts, films, and recipe books to provide an overview of contemporary debates, insights, and politics. Examines how everyday food practices shape gender, religion, caste, and class. Students interested in emerging food trends and consumption will connect with diverse grassroots food initiatives, including food justice initiatives from indigenous communities.",
    section: ["FREE"], rmpScore: 0
  },
  "ANTH 130L": {
