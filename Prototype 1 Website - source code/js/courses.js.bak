  "LIT 133I": {
    title: "Global Japan: Literatures of the Japanese Diaspora",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Examines the fiction of ethnic Japanese writers who are located outside of Japan. How do these writers situate themselves vis-a-vis Japan and the countries in which they were born or reside? How does their status as outsiders enable them to view Japan's social problems and colonial history? Critical approach designations: Genres, Geographies. Distribution requirement: Global.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 133J": {
    title: "Colonial Punjab",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Examines colonial Punjab, focusing on the impact of British rule from the collapse of the Sikh Empire to Partition. Topics include the cultural prehistory of imperialism, colonial governance, Orientalism, and the region's division into India and Pakistan. Students explore the effects of colonialism on Sikh, Hindu, and Muslim communities, the rise of religious reform movements, and the contradictions of colonial rule. Distribution requirement(s): Global.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 133K": {
    title: "Contemporary Asian Literature",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Explores contemporary Asian literature, focusing on how writers from Japan, Korea, Taiwan, and other regions address themes of identity, politics, trauma, and modernity. Through novels, short stories, and essays from the late 20th century to the present, students examine literary movements like surrealism, postmodernism, and magical realism, and how these genres reflect or challenge cultural and societal norms. See the schedule of classes for the current topic. Distribution requirement: Global.",
    section: ["FREE"], rmpScore: 0
  },
