    ge: "TA", quarters: ["F", "W", "S"],
    desc: "A survey of major Romantic themes and authors between 1780 and 1820. Explores relationships to pre-Romantic and post-Romantic authors. The main goal is to achieve familiarity with a wide range of individual poems in the general context of Romanticism. Critical approach designations: Genres, Histories. Distribution requirement: Poetry.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 146B": {
