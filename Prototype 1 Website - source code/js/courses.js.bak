// ============================================================
// courses.js  --  UCSC Course Selection Automation
// Course catalog: every course the planner knows about.
// Source: UCSC 2025-26 General Catalog + fetch_ucsc_courses.py
// ============================================================
//
// Each course has:
//   title    - official course title
//   units    - credit units
//   division - "lower" or "upper"
//   prereqs  - array of OR-groups; ALL groups must be satisfied
//              e.g. [["CSE 20","BME 160"], ["MATH 19A","MATH 20A"]]
//              means (CSE20 OR BME160) AND (MATH19A OR MATH20A)
//   ge       - GE code this course satisfies (null if none)
//   quarters - typical quarters offered: F=Fall, W=Winter, S=Spring
//   desc     - short description
//   section  - which requirement bucket(s) this can fill
//   rmpScore - placeholder Rate My Professor average (0 = no data)
//
// To add more courses, run:
//   python3 scripts/fetch_ucsc_courses.py
//   python3 scripts/merge_into_data_js.py
// ============================================================

