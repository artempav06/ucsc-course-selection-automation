  "LIT 146F": {
    title: "The Dissenting Tradition in America",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Antislavery writing of the 19th century profoundly shaped a resistant strain in American writing. By reading speeches, essays, and life writing along with more traditionally literary work, students examine what gives language the power to move people and to change the world. Critical approach designations: Histories, Power and Subjectivities.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 146G": {
