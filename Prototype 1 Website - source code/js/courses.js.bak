    ge: null, quarters: ["F", "W", "S"],
    desc: "Focuses on how cost data are used by managers in the planning and control of both private- and public-sector organizations. Specific topics include organization of the management and control function, use of cost data for the pricing of goods and services, the effect of cost systems on management performance, and capital budgeting.",
    section: ["FREE"], rmpScore: 0
  },
  "ECON 111A": {
