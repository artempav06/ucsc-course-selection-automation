    prereqs: [["LING 101"], ["LING 111", "LING 112"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "The phonology, morphology, and syntax aspects of French. Some knowledge of French is helpful.",
    section: ["FREE"], rmpScore: 0
  },
  "LING 185": {
