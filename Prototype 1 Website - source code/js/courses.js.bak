    ge: null, quarters: ["F", "W", "S"],
    desc: "The phonology, morphology, and syntax of Russian. Some knowledge of Russian is helpful.",
    section: ["FREE"], rmpScore: 0
  },
  "LING 186": {
    title: "Structure of German",
    units: 5, division: "upper",
    prereqs: [["LING 101"], ["LING 111", "LING 112"]],
    ge: null, quarters: ["F", "W", "S"],
