  "LIT 160C": {
    title: "Cruelty: Enjoying the Pain of Others",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Cruelty is the unmotivated infliction of pain on someone else. This course investigates the notion of cruelty cultures raised by Claude Levi-Strauss through the literatures of ancient Rome and 15th-16th century Mexico as well as contemporary world literature. Critical approach designations: Histories, Power and Subjectivities. Distribution requirements: Global, Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 160E": {
    title: "Theorizing Race and Comics",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Examines comics' origins in the United States' legacies of racial caricature and political cartoons about slavery, Asian exclusion, yellow journalism, and imperial expansion. Analyses of graphic novel's 20th-century evolution around human-rights violations and post-atrocity representational strategies around race, nationalism and minority status. Critical approach designations: Media, Power and Subjectivities. Distribution requirement: Global.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 160F": {
    title: "Topics in Cultural Studies",
    units: 5, division: "upper",
    prereqs: [],
    ge: "TA", quarters: ["F", "W", "S"],
    desc: "Investigates the ways in which cultural texts--literary, aesthetic, visual, performative, and a variety of popular forms--create and transform individual experiences, everyday life, social relations, and power. Course topic changes; see the Class Search for the current topic. Critical approach designations: Media, Power and Subjectivities.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 160G": {
