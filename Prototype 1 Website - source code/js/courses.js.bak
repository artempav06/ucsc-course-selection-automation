  "PHYS 7A": {
    title: "Elementary Physics I",
    units: 5, division: "lower",
    prereqs: [["MATH 11A", "MATH 19A", "MATH 20A", "AM 15A"]],
    ge: "MF", quarters: ["F", "W", "S"],
    desc: "Examines elementary mechanics, including vectors, kinematics, Newton's laws, work and energy, conservation of momentum and energy, fluid motion, and temperature and heat.",
