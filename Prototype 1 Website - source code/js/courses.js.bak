  },
  "LIT 166A": {
    title: "Representations of Gender in Medieval Literature",
    units: 5, division: "upper",
    prereqs: [],
    ge: "TA", quarters: ["F", "W", "S"],
    desc: "Explores medieval literature alongside major contributions to queer and trans theory in order to understand how gender, sex, and sexuality were constructed in premodern Europe. Focuses in particular on erotic expression, courtly tradition, and queer textuality: Chaucer, Gawain, and Heldris de Cornuälle. Distribution requirements: Poetry, Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
