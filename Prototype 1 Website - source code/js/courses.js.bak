  "LIT 121H": {
    title: "Classical Poetics in Elizabethan Verse",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "An introduction to Elizabethan poetry and poetics, with emphasis on shorter lyrics (sonnets, ballads, etc.), pastoral, erotic epyllia, devotional poetry, etc. Examines various Classical and Continental strains of influence at play in the production of English verse in the later 16th century, including Classical rhetoric, Ovidian mythology, and Petrarchanism. Critical approach designations: Canons, Genres. Distribution requirements: Poetry, Pre-1750.",
    section: ["FREE"], rmpScore: 0
