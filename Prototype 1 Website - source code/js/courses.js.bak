    ge: null, quarters: ["F", "W", "S"],
    desc: "Introduces students to important debates in labor studies in Asia. Studies the relationship between labor, capitalism, and imperialism. Also interrogates the relevance or irrelevance of Asia as a concept from the standpoint of labor.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 194U": {
