    units: 5, division: "upper",
    prereqs: [["HIS 100"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Considers through primary and secondary sources the events and aftermath of the Cold War in East Asia in terms of state formation, domestic and foreign policy, and protest movements in China, Taiwan, Korea, and Japan with reference to Vietnam.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 194V": {
