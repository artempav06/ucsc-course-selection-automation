    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Covers the social, cultural, economic, and political history of colonial Mexico (New Spain). Special attention paid to colonial identity formation, religion, and labor systems. Begins by examining indigenous societies prior to the arrival of Europeans and concludes with Mexico's independence movement in the early 19th century.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 134B": {
