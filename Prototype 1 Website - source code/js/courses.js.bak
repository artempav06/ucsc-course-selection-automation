    section: ["FREE"], rmpScore: 0
  },
  "LIT 141B": {
    title: "Classical Chinese Culture and Literature, 10th Century B.C.E. through Sixth Century C.E",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Survey of writing and culture from the 10th century B.C.E. through the sixth century C.E., focusing on poetry, philosophical and historical writing, supernatural fiction, Buddhist/Taoist texts in contexts of fragmentation, empire building, dynastic collapse, rebellion, eremitism, and courtly society. Critical approach designations: Geographies, Histories. Distribution requirements: Global, Poetry, Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 141C": {
    title: "Classical Chinese Culture and Literature, Sixth Century through 16th Century",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Survey of writing and culture from the Tang through early Ming dynasties (sixth century C.E. through 16th century C.E.). Themes include literary, religious, and philosophical innovation; courtly life; cultural contacts with non-Chinese people; and transformations of state and society. Critical approach designations: Geographies, Histories. Distribution requirements: Global, Poetry, Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 141D": {
    title: "Classical Arabic Literature and Islamic Civilization",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Examines the development of classical Arabic literature in historical context, including the appearance and importance of major genres and their broad relationship to the social and cultural history of the Arab-Islamic world. Distribution requirements: Global, Pre-1750. (Formerly Arab-Islamic Literatures I: 500-1200.)",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 141E": {
    title: "Post-Classical Arabic Literature and Culture",
    units: 5, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Examines the evolution of Arabic and Islamic literatures and cultures through the late-Medieval and early-modern periods. These periods produce much of the body of literature and texts that survive today, and is profoundly influential. Distribution requirements: Global, Pre-1750. (Formerly Arab-Islamic Literatures II: 1200-1900.)",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 141G": {
    title: "Granada: The Moor's Last Sigh and the Muslim's Frontier: The City in the Mediterranean Imagination",
    units: 6, division: "upper",
    prereqs: [],
    ge: "CC", quarters: ["F", "W", "S"],
    desc: "Traces the development of Granada from its first rise to prominence as Muslim city in the Ṭāʾifa Period (11th century) through its transformation into a Christian city in early modern Spain. Special emphasis is placed on its role as a point of contact between Spain and North Africa (or the Latin West and the Muslim Mediterranean more broadly) and the city's privileged position in the social and literary imaginaries of Muslims, Christians, and Jews, as a place of memory and intercultural contact. Distribution requirement(s): Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 144A": {
    title: "Continental Renaissance",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Introductory survey of great prose writings of the continental Renaissance in their cultural and historical contexts. Authors include: Machiavelli, Castiglione, Erasmus, Rabelais, Montaigne, and Cervantes. Critical approach designations: Geographies, Histories. Distribution requirement: Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 144G": {
    title: "Unruly Minds and Mental Illness in Literature",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-H", quarters: ["F", "W", "S"],
    desc: "Drawing on a disability studies framework, course explores how portrayals of madness, melancholy, and cognitive nonconformity both limit and expand literary expression. Course examines how mental illness might function as a source of insight or even empowerment, while simultaneously acting as a tool of marginalization. Distribution requirement: Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 145A": {
