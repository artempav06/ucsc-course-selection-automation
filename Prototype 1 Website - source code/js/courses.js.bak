    desc: "Explores the political, social, economic, and cultural development of British North America from the first stirrings of resistance to the establishment of the U.S. Course 110A is not a prerequisite to course 110B.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 110D": {
    title: "The Civil War Era",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Social, political, and economic history of the American Civil War and Reconstruction, focusing on the war's changing nature and significance, emancipation, and the postwar struggle over the future of the South and the nation.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 110E": {
    title: "Rise of the Machines: Technology, Inequality, and the United States, 1877 to 1914",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PE-T", quarters: ["F", "W", "S"],
    desc: "History of the U.S. during what was perhaps its most socially turbulent era, the period following Reconstruction through the First World War. What did it mean to be a nation in the post-Reconstruction era? How did a country that had only recently unified itself under one system of labor now resolve the question of national identity? Was America truly a nation by 1914?",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 110F": {
    title: "World War USA: The United States from 1914 through 1945",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Between the First and Second World Wars, American society accepted the need for a regulatory state to save capitalism from itself. Takes an in-depth look at many aspects of U.S. politics and culture during these years.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 110G": {
    title: "Strange Days: The USA and its National Security State, 1945-1991",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "From the Good War to the Cold War, the Sixties to the rise of the New Right, the post-1945 American experience has been one of extremes. This survey course looks for evidence of commonality during those times. (Formerly Age of Extremes: The United States During the Cold War, 1945 to 1991)",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 110H": {
