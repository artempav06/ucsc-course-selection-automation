    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Speaking, reading, and writing proficiency in German required. Selected readings of major German dramatists; attention given to various movements in theater. Critical approach designations: Canons, Media.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 183I": {
    title: "Deutscher Film: Geschichte, Kultur, Gesellschaft",
    units: 5, division: "upper",
    prereqs: [],
    ge: "IM", quarters: ["F", "W", "S"],
    desc: "Speaking, reading, and writing proficiency in German required. Course plots the thematic and formal trajectories of cinema in the German Democratic Republic between 1946 and 1992 to examine the key stress lines of socialist culture in East Germany. Critical approach designations: Histories, Media. (Formerly German Cinema: History, Culture, and Society.)",
    section: ["FREE"], rmpScore: 0
