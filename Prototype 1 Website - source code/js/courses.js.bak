  "BIOE 125": {
    title: "Ecosystems of California",
    units: 5, division: "upper",
    prereqs: [["BIOE 20C"]],
    ge: "PE-E", quarters: ["F", "W", "S"],
    desc: "A survey of the diversity, structure, and functioning of California's ecosystems through time and the ways they have influenced and responded to human activities and stewardship. Topics include: ecosystem drivers such as climate, soils, and land-use history; human and ecological prehistory; comparative marine, freshwater, and terrestrial ecosystem dynamics; and managed ecosystems such as range, fisheries, and agriculture.",
