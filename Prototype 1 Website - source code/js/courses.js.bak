  "LIT 101": {
    title: "Theory and Interpretation",
    units: 5, division: "upper",
    prereqs: [],
    ge: "TA", quarters: ["F", "W", "S"],
    desc: "Contemporary approaches to literary and cultural theory, with emphasis on how theoretical perspectives advance and broaden the reading of literary texts. Introduction to important new theoretical developments and their antecedents. Literature majors should complete this course as early as possible. Course topic changes; see the Class Search for the current topic.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 102": {
    title: "Translation Theory",
    units: 5, division: "upper",
    prereqs: [],
    ge: "TA", quarters: ["F", "W", "S"],
    desc: "Promotes the understanding of translation and its role in redefining meanings across epochs and cultures, in establishing common norms, and in advancing mutual intelligibility; but also providing encounters with absolute alterity. Actual translations are used as case studies.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 108A": {
    title: "Literature Internships",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PR-S", quarters: ["F", "W", "S"],
    desc: "Provides literature majors with pre-professional experience in a variety of fields to enable students to envision career pathways and to conceive of multiple ways for literature and humanities majors to work in and engage the world. Students meet three times as a cohort during the quarter of their internship and keep a reflective journal during that time, with a brief final report at the end. Internships can be located on or off campus. Enrollment is by application through the Literature Department website. Enrollment is restricted to declared and proposed literature majors and Italian studies minors.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 108B": {
    title: "Literature Internships 2",
    units: 2, division: "upper",
    prereqs: [],
    ge: "PR-S", quarters: ["F", "W", "S"],
    desc: "Provides literature majors with pre-professional experience in a variety of fields to enable students to envision career pathways and to conceive of multiple ways for literature and humanities majors to work in and engage the world. Students meet three times as a cohort during the quarter of their internship and keep a reflective journal during that time, with a brief final report at the end. Internships can be located on or off campus. Enrollment by application through the Literature Department website. Enrollment is restricted to literature majors and minors and proposed literature majors and Italian studies minors.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 109X": {
    title: "Marxist Literary Criticism",
    units: 5, division: "upper",
    prereqs: [],
    ge: "TA", quarters: ["F", "W", "S"],
    desc: "This course is an opportunity for students to engage with the tradition of Marxist literary and cultural criticism. The course begins with Marx’s own writings and then explores how Marx’s thought has been adapted and developed in diverse contexts, but always taking as its point of departure the complicated relationships between social life, exploitation, and regimes of representation from classical modernity through the present. The class is intended to focus on methodological and theoretical approaches to the study of culture.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 110A": {
    title: "The Traditional British Canon, Part I",
    units: 5, division: "upper",
    prereqs: [],
    ge: "TA", quarters: ["F", "W", "S"],
    desc: "The constitution of the canon of English literature from Chaucer to Cowper. Critical approach designations: Canons. Histories. Distribution requirements: Poetry, Pre-1750.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 110B": {
    title: "The Traditional British Canon, Part II",
    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Explores poetry and prose from 1800 to 1950 through extensive reading in the Romantics, Victorians, Moderns, articulating the connections among them, and connecting their work to key social, political, scientific, and technological moments defining these eras. Critical approach designations: Canons, Histories. Distribution requirement: Poetry.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 110C": {
