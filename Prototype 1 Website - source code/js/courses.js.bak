    ge: null, quarters: ["F", "W", "S"],
    desc: "Focuses on physiological, behavioral, and population ecology, and on linking ecological processes to evolution. It includes basic principles, experimental approaches, concepts of modeling, and applications to ecological problems.",
    section: ["FREE"], rmpScore: 0
  },
  "BIOE 108": {
