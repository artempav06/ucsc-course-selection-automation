    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Independent laboratory research on selected topics in archeology and physical anthropology. Interview with appropriate instructor required.",
    section: ["FREE"], rmpScore: 0
  },
