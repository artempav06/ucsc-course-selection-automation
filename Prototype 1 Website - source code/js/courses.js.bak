  },
  "PHYS 102": {
    title: "Modern Physics",
    units: 5, division: "upper",
    prereqs: [["PHYS 5A", "PHYS 5L", "PHYS 5B", "PHYS 5M", "PHYS 5C", "PHYS 5N"], ["PHYS 5D"], ["PHYS 6A", "PHYS 6L", "PHYS 6B", "PHYS 6M", "PHYS 6C", "PHYS 6N"], ["PHYS 5D"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Topics in quantum physics including the Schrodinger equation; angular momentum and spin; the Pauli exclusion principle; and quantum statistics. Applications in multi-electron atoms and molecules, and in solid-state, nuclear, and particle physics.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 105": {
    title: "Mechanics",
    units: 5, division: "upper",
    prereqs: [["PHYS 5A"], ["PHYS 5L"], ["PHYS 116A", "MATH 21", "MATH 24", "AM 10", "AM 20"], ["ASTR 119", "CSE 20"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Particle dynamics in one, two, and three dimensions. Conservation laws. Small oscillations, Fourier series and Fourier integral solutions. Phase diagrams and nonlinear motions, Lagrange's equations, and Hamiltonian dynamics.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 110A": {
    title: "Electricity, Magnetism, and Optics",
    units: 5, division: "upper",
    prereqs: [["PHYS 5C"], ["PHYS 116A", "MATH 21"], ["MATH 24"], ["PHYS 116C", "MATH 107"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Examines electrostatics, including the electric field, potential, solutions to Laplace's and Poisson's equations, and work and energy; electricity in matter (conductors, dielectrics); magnetostatics, including the magnetic field and vector potential, Ampere's and Faraday's laws; magnetism in matter; and Maxwell's equations.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 110B": {
    title: "Electricity, Magnetism, and Optics",
    units: 5, division: "upper",
    prereqs: [["PHYS 110A"], ["PHYS 116C", "MATH 107"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Examines electromagnetic waves, including absorption and dispersion, reflection and transmission, and wave guides; conservation laws and gauge invariance; time-dependent vector and scalar potentials and application to radiation of charges and antennae; and electrodynamics and relativity.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 112": {
    title: "Thermodynamics and Statistical Mechanics",
    units: 5, division: "upper",
    prereqs: [["PHYS 5D"], ["MATH 23B"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Consequences of the first and second laws of thermodynamics, elementary statistical mechanics, thermodynamics of irreversible processes.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 115": {
    title: "Computational Physics",
    units: 5, division: "upper",
    prereqs: [["PHYS 102"], ["PHYS 105"], ["PHYS 116A", "MATH 21"], ["MATH 24"], ["PHYS 116C", "MATH 107"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "This course applies efficient numerical methods to the solutions of problems in the physical sciences which are otherwise intractable. Examples will be drawn from classical mechanics, quantum mechanics, statistical mechanics, and electrodynamics. Students apply a high-level programming language, such as Python, to the solution of physical problems and develop appropriate error and stability estimates.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 116A": {
    title: "Mathematical Methods in Physics",
    units: 5, division: "upper",
    prereqs: [["MATH 23A"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Infinite series. Topics in linear algebra including vector spaces, matrices and determinants, systems of linear equations, eigenvalue problems and matrix diagonalization. Ordinary differential equations and Laplace transforms.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 116C": {
    title: "Mathematical Methods in Physics",
    units: 5, division: "upper",
