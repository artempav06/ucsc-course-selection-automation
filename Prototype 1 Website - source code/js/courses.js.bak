    section: ["FREE"], rmpScore: 0
  },
  "LIT 160H": {
    title: "Topics In Narratives of Resistance",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Selections from writers from around the world, whose common theme is resistance to domination. In most cases, the domination is multiple and complex, involving gender oppression, and racial and colonial domination. Distribution requirement: Global. (Formerly Narratives of Resistance.)",
