    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Examines the thought and activities of W.E.B. Du Bois across changing historical circumstances. Considers the ways Du Bois's work has been used in the present to address issues such as racism and imperialism.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 121A": {
    title: "African American History to 1877",
    units: 5, division: "upper",
    prereqs: [],
    ge: "ER", quarters: ["F", "W", "S"],
    desc: "Surveys the history and freedom struggle of African Americans from early beginnings in indigenous Africa to the end of Reconstruction. Topics include the North American colonization project, the transatlantic and domestic slave trade, seasoning, slavery and abolitionism, women’s resistance, the Civil War, and post-emancipation.",
    section: ["FREE"], rmpScore: 0
  },
  "HIS 121B": {
