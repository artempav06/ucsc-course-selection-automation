  "PHYS 1A": {
    title: "Physics for Everyone",
    units: 5, division: "lower",
    prereqs: [],
    ge: "SI", quarters: ["F", "W", "S"],
    desc: "Explores some of the great topics in classical and modern physics, including relativity, and the connections to a broad range of inquiry, from daily life to cosmology. Math, mainly algebra, is used in a way that is completely accessible to everyone. No previous knowledge of physics is necessary.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 1B": {
    title: "Physics for Everyone",
    units: 5, division: "lower",
    prereqs: [],
    ge: "SR", quarters: ["F", "W", "S"],
    desc: "Explores some of the great topics in classical and modern physics, including thermal physics, quantum mechanics, and the constituents of matter, and their connections to a broad range of inquiry, from daily life to particle physics and cosmology. Probabilistic evidence, backgrounds, statistical fluctuations and systematic uncertainties, discovery significance, what we infer, and what can go wrong, are illustrated in some depth. Math is used in a way that is completely accessible to everyone. No previous knowledge of physics or statistics is necessary.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 2": {
    title: "The Physicist's Toolbox",
    units: 2, division: "lower",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Prepares students for success in subsequent classes in physics and astrophysics. Course is designed for students majoring or considering majoring in physics, applied physics, or astrophysics. Includes overview of physics and astrophysics, and their major tools: experiment, theory, observation, and computation. Provides conceptual overview of the top-level theoretical approaches including classical mechanics, quantum mechanics, and statistical mechanics. Also reviews problem-solving skills for work in subsequent classes, including the physicist's approach to calculus, working intuitively with graphs, solving simultaneous equations, and understanding equations conceptually. Examines the educational path to different physics careers, physics as a collaborative discipline, and effective methods for group work as well as individual study.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 5A": {
    title: "Introduction to Physics I",
    units: 5, division: "lower",
    prereqs: [["MATH 19A", "MATH 20A"]],
    ge: "MF", quarters: ["F", "W", "S"],
    desc: "Elementary mechanics. Vectors, Newton's laws, inverse square force laws, work and energy, conservation of momentum and energy, and oscillations.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 5B": {
    title: "Introduction to Physics II",
    units: 5, division: "lower",
    prereqs: [["PHYS 5A"], ["MATH 19B", "MATH 20B"], ["PHYS 5M"]],
    ge: "SI", quarters: ["F", "W", "S"],
    desc: "A continuation of PHYS 5A . Wave motion in matter, including sound waves. Geometrical optics, interference and polarization, statics and dynamics of fluids.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 5C": {
    title: "Introduction to Physics III",
    units: 5, division: "lower",
    prereqs: [["PHYS 5A"], ["MATH 19B", "MATH 20B"]],
    ge: "SI", quarters: ["F", "W", "S"],
    desc: "Introduction to electricity and magnetism. Electromagnetic radiation, Maxwell's equations.",
    section: ["FREE"], rmpScore: 0
  },
  "PHYS 5D": {
    title: "Introduction to Physics IV",
    units: 5, division: "lower",
    prereqs: [["PHYS 5A"], ["PHYS 5L", "PHYS 6A"], ["PHYS 6L"], ["PHYS 5B", "PHYS 6B"], ["MATH 19B", "MATH 20B"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Introduces temperature, heat, thermal conductivity, diffusion, ideal gases, laws of thermodynamics, heat engines, and kinetic theory. Introduces the special theory of relativity and the equivalence principle. Includes the photoelectric effect, the Compton effect, matter waves, atomic spectra, and the Bohr model.",
    section: ["FREE"], rmpScore: 0
  },
