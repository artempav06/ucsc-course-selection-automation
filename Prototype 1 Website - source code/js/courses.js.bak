    ge: null, quarters: ["F", "W", "S"],
    desc: "Advanced topics in inorganic chemistry and an introduction to solid-state chemistry. Synthesis and structure of materials discussed as well as their influence on properties for modern devices and applications. Recent developments in area of material science also explored. Taught in conjunction with CHEM 256C.",
    section: ["FREE"], rmpScore: 0
  },
  "CHEM 160J": {
    title: "Biochemistry Research Laboratory",
    units: 5, division: "upper",
    prereqs: [["CHEM 8L"], ["BIOC 100A", "BIOL 100", "CHEM 103"]],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Introduction to hypothesis-driven laboratory research. Students collectively design and execute a novel research project that addresses a question about macromolecular structure, function, or regulation. Working individually and in small groups, students learn aspects of experimental design, literature and public data base research, data analysis and interpretation, and scientific collaboration. Learned laboratory techniques include molecular cloning, recombinant protein expression and purification, and biochemical assay implementation.",
