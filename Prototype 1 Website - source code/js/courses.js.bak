    units: 5, division: "lower",
    prereqs: [],
    ge: "PR-C", quarters: ["F", "W", "S"],
    desc: "This intermediate-level course will explore prose writing from a bilingual (Spanish-English) perspective. Primarily in English, but may delve into Spanish passages or phrasing. Work can be completed in English, Spanish, or Spanglish.",
    section: ["FREE"], rmpScore: 0
