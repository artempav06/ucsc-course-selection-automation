    units: 5, division: "upper",
    prereqs: [],
    ge: null, quarters: ["F", "W", "S"],
    desc: "Examines the genre of travel writing and the critical and cultural issues it engages. Critical approach designations: Genres, Geographies. Distribution requirements: Global.",
    section: ["FREE"], rmpScore: 0
  },
  "LIT 127J": {
    title: "How to Write Like a Journalist",
    units: 5, division: "upper",
    prereqs: [],
    ge: "PR-C", quarters: ["F", "W", "S"],
    desc: "Journalists generally talk about two kinds of stories: hard news and features. Hard news stories make you smarter. Features make you wiser. We'll be reading and writing both sorts in this class. We'll also be tweeting, taking photos, experimenting with opinion pieces and learning how journalistic writing differs from academic writing. We'll be analyzing the work of today's professional journalists (some will visit our class) and talking about where their articles succeed and fail. The class is highly interactive and students work both on their own and in teams. Course includes reading news weekly and writing news stories about campus and the community.",
    section: ["FREE"], rmpScore: 0
  },
