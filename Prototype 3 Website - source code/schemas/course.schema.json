{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucsc-scheduler.local/schemas/course.schema.json",
  "title": "Prototype 3 Course",
  "type": "object",
  "required": ["title", "units", "division", "prereqs", "ge", "quarters", "desc", "section", "rmpScore"],
  "additionalProperties": true,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "units": { "type": "number", "minimum": 0 },
    "division": { "enum": ["lower", "upper", "graduate"] },
    "prereqs": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      }
    },
    "ge": { "type": ["string", "null"] },
    "quarters": {
      "type": "array",
      "items": { "enum": ["F", "W", "S", "SU"] },
      "uniqueItems": true
    },
    "desc": { "type": "string" },
    "section": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "rmpScore": { "type": "number" },
    "catalogUrl": { "type": "string" },
    "enrollmentRestrictions": { "type": "string" },
    "labCoreq": { "type": "string" },
    "repeatable": {}
  }
}
